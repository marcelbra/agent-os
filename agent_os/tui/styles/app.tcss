/* Tree width matches _TREE_WIDTH in nav.py — keep in sync if changed. */
NavTree {
    width: 30;
    min-width: 30;
    border-right: heavy #30363d;
    background: #0d1117;
    overflow-x: hidden;
    scrollbar-size: 0 0;
}
NavTree .tree--highlight {
    background: transparent;
}
NavTree .tree--highlight-line {
    background: transparent;
}

#detail {
    width: 1fr;
    padding: 1 3;
    background: #0d1117;
    scrollbar-size: 0 0;
}

DetailTextArea {
    border: tall #30363d;
    background: #161b22;
    color: #c9d1d9;
    height: 1fr;
    min-height: 8;
    scrollbar-size: 0 0;
}
DetailTextArea:focus {
    border: tall #58a6ff;
}
